\NeedsTeXFormat{LaTeX2e}

% Pin the CJK fonts to the Windows ctexart defaults vendored in this repo.
% This keeps the output stable across machines while matching Windows ctex.
\RequirePackage{iftex}
\ifPDFTeX
  \PackageError{course-alchemist-review}
    {This template requires XeLaTeX or LuaLaTeX}
    {Use xelatex for the Windows ctexart-compatible font setup.}
\fi
\RequirePackage{fontspec}

\newcommand{\CAWindowsCtexFontPath}{}
\makeatletter
\IfFileExists{assets/fonts/windows-ctex/simsun.ttc}
  {\renewcommand{\CAWindowsCtexFontPath}{assets/fonts/windows-ctex/}}
  {%
    \IfFileExists{../fonts/windows-ctex/simsun.ttc}
      {\renewcommand{\CAWindowsCtexFontPath}{../fonts/windows-ctex/}}
      {%
        \IfFileExists{../../../fonts/windows-ctex/simsun.ttc}
          {\renewcommand{\CAWindowsCtexFontPath}{../../../fonts/windows-ctex/}}
          {%
            \IfFileExists{../../../../fonts/windows-ctex/simsun.ttc}
              {\renewcommand{\CAWindowsCtexFontPath}{../../../../fonts/windows-ctex/}}
              {%
                \PackageError{course-alchemist-review}
                  {Cannot find vendored Windows ctex fonts}
                  {Expected simsun.ttc under assets/fonts/windows-ctex.}
              }%
          }%
      }%
  }
\makeatother

\setCJKmainfont[
  Path=\CAWindowsCtexFontPath,
  BoldFont=simhei.ttf,
  ItalicFont=simkai.ttf
]{simsun.ttc}
\setCJKsansfont[
  Path=\CAWindowsCtexFontPath,
  BoldFont=msyhbd.ttc
]{msyh.ttc}
\setCJKmonofont[
  Path=\CAWindowsCtexFontPath
]{simfang.ttf}
\setCJKfamilyfont{zhsong}[
  Path=\CAWindowsCtexFontPath,
  BoldFont=simhei.ttf,
  ItalicFont=simkai.ttf
]{simsun.ttc}
\setCJKfamilyfont{zhhei}[
  Path=\CAWindowsCtexFontPath
]{simhei.ttf}
\setCJKfamilyfont{zhfs}[
  Path=\CAWindowsCtexFontPath
]{simfang.ttf}
\setCJKfamilyfont{zhkai}[
  Path=\CAWindowsCtexFontPath
]{simkai.ttf}
\setCJKfamilyfont{zhyahei}[
  Path=\CAWindowsCtexFontPath,
  BoldFont=msyhbd.ttc
]{msyh.ttc}
\setCJKfamilyfont{zhli}[
  Path=\CAWindowsCtexFontPath
]{simli.ttf}
\setCJKfamilyfont{zhyou}[
  Path=\CAWindowsCtexFontPath
]{simyou.ttf}

% Page and typography
\RequirePackage[
  a4paper,
  left=1.55cm,
  right=1.55cm,
  top=1.65cm,
  bottom=1.8cm,
  headheight=14pt,
  headsep=0.45cm,
  footskip=0.85cm
]{geometry}
\RequirePackage{setspace}
\setstretch{1.12}
\setlength{\parindent}{2em}
\setlength{\parskip}{0.25em}

% Math and diagrams
\RequirePackage{amsmath,amssymb,mathtools,bm}
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}

% Lists, tables, links
\RequirePackage{booktabs,array,tabularx}
\RequirePackage{enumitem}
\setlist[itemize]{leftmargin=2em,itemsep=0.15em,topsep=0.25em}
\setlist[enumerate]{leftmargin=2.2em,itemsep=0.15em,topsep=0.25em}
\RequirePackage[hidelinks]{hyperref}
\hypersetup{
  pdfauthor={Course Alchemist}
}

% Header and footer
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small \CAHeaderTitle}
\fancyhead[R]{\small \leftmark}
\fancyfoot[C]{\small \thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}

% Colors and boxed environments
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{breakable,skins,theorems}

\definecolor{CAInk}{HTML}{1F2937}
\definecolor{CASubtle}{HTML}{F8FAFC}
\definecolor{CADef}{HTML}{2563EB}
\definecolor{CAThm}{HTML}{7C3AED}
\definecolor{CALem}{HTML}{0891B2}
\definecolor{CAHint}{HTML}{059669}
\definecolor{CAExam}{HTML}{D97706}
\definecolor{CAPitfall}{HTML}{DC2626}
\definecolor{CANote}{HTML}{475569}
\definecolor{CAMethod}{HTML}{0F766E}
\definecolor{CAExample}{HTML}{4F46E5}

\tcbset{
  ca-base/.style={
    enhanced,
    breakable,
    sharp corners,
    boxrule=0.6pt,
    leftrule=2.4pt,
    arc=1.2mm,
    left=1.1mm,
    right=1.1mm,
    top=0.9mm,
    bottom=0.9mm,
    before skip=0.65em,
    after skip=0.65em,
    fonttitle=\bfseries,
    coltitle=CAInk
  }
}

\newtcbtheorem[number within=section]{definition}{定义}{
  ca-base,
  colback=CADef!5,
  colframe=CADef,
  colbacktitle=CADef!12
}{def}

\newtcbtheorem[number within=section]{theorem}{定理}{
  ca-base,
  colback=CAThm!5,
  colframe=CAThm,
  colbacktitle=CAThm!12
}{thm}

\newtcbtheorem[number within=section]{lemma}{引理}{
  ca-base,
  colback=CALem!5,
  colframe=CALem,
  colbacktitle=CALem!12
}{lem}

\newtcbtheorem[number within=section]{hint}{提示}{
  ca-base,
  colback=CAHint!5,
  colframe=CAHint,
  colbacktitle=CAHint!12
}{hint}

\newtcbtheorem[number within=section]{examspot}{考点}{
  ca-base,
  colback=CAExam!7,
  colframe=CAExam,
  colbacktitle=CAExam!14
}{exam}

\newtcbtheorem[number within=section]{pitfall}{易错点}{
  ca-base,
  colback=CAPitfall!5,
  colframe=CAPitfall,
  colbacktitle=CAPitfall!12
}{pit}

\newtcbtheorem[number within=section]{attention}{关注}{
  ca-base,
  colback=CANote!6,
  colframe=CANote,
  colbacktitle=CANote!14
}{att}

\newtcbtheorem[number within=section]{method}{方法}{
  ca-base,
  colback=CAMethod!5,
  colframe=CAMethod,
  colbacktitle=CAMethod!12
}{mtd}

\newtcbtheorem[number within=section]{example}{例题}{
  ca-base,
  colback=CAExample!5,
  colframe=CAExample,
  colbacktitle=CAExample!12
}{ex}

\newtcolorbox{solutionbox}[1][]{%
  ca-base,
  title={解答},
  colback=CASubtle,
  colframe=CAInk!55,
  colbacktitle=CAInk!8,
  #1
}

% Common commands
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\dd}{\,\mathrm{d}}

% Document metadata helpers
\newcommand{\CourseName}{课程名称}
\newcommand{\LectureTitle}{复习讲义标题}
\newcommand{\CAHeaderTitle}{\LectureTitle}
\newcommand{\CASetCourseName}[1]{\renewcommand{\CourseName}{#1}}
\newcommand{\CASetLectureTitle}[1]{%
  \renewcommand{\LectureTitle}{#1}%
  \renewcommand{\CAHeaderTitle}{#1}%
  \hypersetup{pdftitle={#1}}%
}
\newcommand{\CASetHeaderTitle}[1]{\renewcommand{\CAHeaderTitle}{#1}}
